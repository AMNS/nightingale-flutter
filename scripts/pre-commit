#!/bin/sh
# Pre-commit hook: enforce code quality before every commit.
# Runs: cargo fmt --check, cargo clippy, cargo test, golden bitmap diff
# All checks must pass or the commit is rejected.
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or run: ./scripts/install-hooks.sh

set -e

echo "Running pre-commit checks..."
echo ""

# 1. Check formatting
echo "1/4: Checking formatting (cargo fmt)..."
if ! cargo fmt -- --check 2>&1; then
    echo ""
    echo "ERROR: Code is not formatted. Run 'cargo fmt' and re-stage."
    exit 1
fi
echo "    Formatting OK."
echo ""

# 2. Run clippy
echo "2/4: Running clippy..."
if ! cargo clippy --all-targets -- -D warnings 2>&1; then
    echo ""
    echo "ERROR: Clippy found warnings. Fix them and retry."
    exit 1
fi
echo "    Clippy OK."
echo ""

# 3. Run tests (includes bitmap regression)
echo "3/4: Running tests (cargo test)..."
if ! cargo test 2>&1; then
    echo ""
    echo "ERROR: Tests failed. Commit aborted."
    echo "Fix the failing tests or use 'git commit --no-verify' to skip this check."
    exit 1
fi
echo ""

# 4. Show visual diff summary for golden bitmaps
echo "4/4: Checking golden bitmap diffs..."
echo "(any changed bitmaps are shown below — review before pushing)"
cargo test --test golden_diff -- --nocapture 2>&1 | grep -E '^\[|^=|^  |^open |^Unchanged|^Changed|^New' || true
echo "    Golden diff check complete."
echo ""

echo "All pre-commit checks passed."
