%!PS-Adobe-2.0 EPSF-1.2%%Title: 02.ng.EPSF%%Creator: Nightingale 5.0.7a9%%CreationDate: Wed, Mar 10, 2004 [1:05:09 pm]%%Pages: 1%%BoundingBox: 0 0 594 841%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF 16 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 841] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/MFS 16 def16 MF SQW/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def5280 961 576 961 SFL5280 1025 576 1025 SFL5280 1089 576 1089 SFL5280 1153 576 1153 SFL5280 1217 576 1217 SFL5280 1577 576 1577 SFL5280 1641 576 1641 SFL5280 1705 576 1705 SFL5280 1769 576 1769 SFL5280 1833 576 1833 SFL576 1835 576 959 6 ML464 961 436 BR(&)640 1217 MS(?)640 1833 MS/Times-Italic 8 NF(13)832 865 MS16 MF SQW(\344)1074 1057 MS(\317)1074 1577 1074 1586 1074 1801 SD(\344)1074 1249 MS1415 1281 1295 1281 LL(\317)1319 1281 1319 1290 1319 1505 SD(J)1319 1281 MS(\317)1319 1121 MS1319 897 0 SU(j)1319 1121 MS(\317)1564 1217 1564 1226 1564 1441 SD(\317)1564 1057 MS1564 833 0 SU(\344)1564 1673 MS(\317)1810 1577 1810 1586 1810 1801 SD(J)1810 1577 MS2159 1513 2039 1513 LL(\317)2063 1513 2063 1522 2063 1737 SD(\344)2063 1249 MS(\344)2063 1057 MS(\317)2309 1153 MS2309 929 0 SU(j)2309 1153 MS(\317)2309 1217 2309 1226 2309 1441 SD(J)2309 1217 MS2625 849 2981 833 32 BM2977 881 2917 883 32 BM(\344)2554 1673 MS(\317)2554 1089 MS2554 857 0 SU(.)2666 1057 MS(\317)2554 1153 2554 1162 2554 1377 SD(\317)2808 1833 2808 1842 2808 2057 SD(J)2808 1833 MS(\317)2906 1057 MS2906 841 0 SU3069 1833 3069 961 BL3167 1961 3584 1945 32 BM3584 1897 3520 1899 32 BM(\317)3167 1025 MS3167 801 0 SU(\317)3167 1769 3167 1778 3167 1993 SD(.)3279 1801 MS(\344)3167 1481 MS3508 1513 3388 1513 LL(\317)3412 1481 MS3412 1257 0 SU(j)3412 1481 MS(\317)3584 1737 3584 1746 3584 1977 SD3818 1401 4174 1385 32 BM4170 1433 4110 1435 32 BM(\317)3747 1641 MS3747 1409 0 SU(.)3859 1609 MS(\317)3747 1705 3747 1714 3747 1929 SD(\344)3747 1057 MS(\317)3993 1249 MS3993 1025 0 SU(j)3993 1249 MS(\317)4099 1609 MS4099 1393 0 SU4334 945 4689 929 32 BM4685 977 4625 979 32 BM(\317)4263 1577 MS4263 1353 0 SU(.)4375 1545 MS(\344)4263 1801 MS(\317)4263 1185 MS4263 953 0 SU(.)4375 