%!PS-Adobe-2.0 EPSF-1.2%%Title: Ich bin ja with voice.ng.ps%%Creator: Nightingale 4.5%%CreationDate: Sun, Nov 7, 2004 [12:13:39 PM]%%Pages: 2%%BoundingBox: 0 0 595 842%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF DCF 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 842] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/MFS 14 def14 MF SQW/stw 4 def/blw 5 def/ldw 7 def/sfw 4 def8368 1768 2092 1768 SFL8368 1824 2092 1824 SFL8368 1880 2092 1880 SFL8368 1936 2092 1936 SFL8368 1992 2092 1992 SFL8368 2211 2092 2211 SFL8368 2267 2092 2267 SFL8368 2323 2092 2323 SFL8368 2379 2092 2379 SFL8368 2435 2092 2435 SFL8368 1208 2092 1208 SFL8368 1264 2092 1264 SFL8368 1320 2092 1320 SFL8368 1376 2092 1376 SFL8368 1432 2092 1432 SFL2092 2437 2092 1206 5 ML1994 1768 333 BR/Times-Roman 11 NF()2148 1012 MS14 MF SQW(&)2148 1992 MS(?)2148 2435 MS(&)2148 1432 MS(b)2344 1880 MS(b)2344 2387 MS(4)2428 1824 MS(4)2428 1936 MS(4)2428 2267 MS(4)2428 2379 MS(4)2428 1264 MS(4)2428 1376 MS2745 1987 3038 1994 28 BM2918 2033 3038 2036 28 BM2766 2155 2661 2155 LL(\317)2682 2155 MS2682 1995 0 SU(\317)2682 2463 2682 2471 2682 2617 SD(\317)2855 2211 MS2855 1999 0 SU(\317)2971 2183 MS2971 2002 0 SU3149 1899 3499 1913 28 BM3149 1941 3499 1955 28 BM3170 2155 3065 2155 LL(\317)3086 2155 MS3086 1907 0 SU(\317)3086 2463 3086 2471 3086 2617 SD3285 2155 3180 2155 LL3285 2099 3180 2099 LL(\317)3201 2071 MS3201 1911 0 SU3401 2155 3296 2155 LL(\317)3317 2127 MS3317 1915 0 SU(\317)3432 2211 MS3432 1921 0 SU3611 2015 3903 2022 28 BM3784 2061 3903 2064 28 BM(\317)3548 2183 MS3548 2023 0 SU(\317)3548 2463 3548 2471 3548 2617 SD(\317)3721 2239 MS3721 2027 0 SU(\317)3836 2211 MS3836 2030 0 SU4015 1959 4365 1959 28 BM4015 2001 4365 2001 28 BM(\317)3952 2183 MS3952 1967 0 SU4036 2491 3931 2491 LL(\317)3952 2491 3952 2499 3952 2645 SD4151 2155 4046 2155 LL(\317)4067 2127 MS4067 1967 0 SU(\317)4182 2239 MS4182 1967 0 SU(\317)4298 2183 MS4298 1967 0 SU4413 2435 4413 1768 BL4413 1432 4413 1208 BL4562 1987 4912 1987 28 BM4562 2029 4912 2029 28 BM(\317)4499 2211 MS4499 1995 0 SU(\317)4499 2463 4499 2471 4499 2617 SD4698 2155 4593 2155 LL