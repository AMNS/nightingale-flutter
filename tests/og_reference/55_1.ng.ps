%!PS-Adobe-2.0 EPSF-1.2%%Title: 55_1.ng.ps%%Creator: Nightingale 4.5%%CreationDate: Mon, Jun 19, 2006 [2:32:19 PM]%%Pages: 5%%BoundingBox: 0 0 842 595%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF DCF 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 595] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/MFS 18 def18 MF SQW/stw 5 def/blw 7 def/ldw 9 def/sfw 5 def12896 2645 1792 2645 SFL12896 2717 1792 2717 SFL12896 2789 1792 2789 SFL12896 2861 1792 2861 SFL12896 2933 1792 2933 SFL12896 3077 1792 3077 SFL12896 3149 1792 3149 SFL12896 3221 1792 3221 SFL12896 3293 1792 3293 SFL12896 3365 1792 3365 SFL/Times-Roman 11 NF(Liuto)898 3037 MS12896 1432 1792 1432 SFL12896 1504 1792 1504 SFL12896 1576 1792 1576 SFL12896 1648 1792 1648 SFL12896 1720 1792 1720 SFL/Times-Roman 11 NF(Violino I)770 1608 MS12896 2017 1792 2017 SFL12896 2089 1792 2089 SFL12896 2161 1792 2161 SFL12896 2233 1792 2233 SFL12896 2305 1792 2305 SFL/Times-Roman 11 NF(Violino II)738 2193 MS12896 4383 1792 4383 SFL12896 4455 1792 4455 SFL12896 4527 1792 4527 SFL12896 4599 1792 4599 SFL12896 4671 1792 4671 SFL/Times-Roman 11 NF(Contrabasso)658 4559 MS12896 3860 1792 3860 SFL12896 3932 1792 3932 SFL12896 4004 1792 4004 SFL12896 4076 1792 4076 SFL12896 4148 1792 4148 SFL/Times-Roman 11 NF(Violoncello)674 4036 MS1792 4673 1792 1430 7 ML11 MF SQW873 1738 1432 BK811 1738 3860 BK18 MF SQW(&)1864 2933 MS(?)1864 3365 MS(&)1864 1720 MS(&)1864 2305 MS(?)1864 4671 MS(?)1864 4148 MS(b)2098 2789 MS(b)2179 2677 MS(b)2260 2821 MS(b)2098 3301 MS(b)2179 3189 MS(b)2260 3333 MS(b)2098 1576 MS(b)2179 1464 MS(b)2260 1608 MS(b)2098 2161 MS(b)2179 2049 MS(b)2260 2193 MS(b)2098 4607 MS(b)2179 4495 MS(b)2260 4639 MS(b)2098 4084 MS(b)2179 3972 MS(b)2260 4116 MS/Times-Bold 11 NF()2440 1216 MS18 MF SQW(3)2440 2717 MS(4)2440 2861 MS(3)2440 3149 MS(4)2440 3293 MS(3)2440 1504 MS(4)2440 1648 MS(3)2440 2089 MS(4)2440 2233 MS(3)2440 4455 MS(4)2440 4599 MS(3)2440 3932 MS(4)2440 4076 MS(\267)3264 1576 MS(\317)2765 2233 MS2765 1981 0 SU(\317)2765 3113 MS2765 2861 0 SU(\267)3264 3437 MS(\267)3264 4004 MS(\267)3264 4527 MS(\317)3164 3257 MS3164 3005 0 