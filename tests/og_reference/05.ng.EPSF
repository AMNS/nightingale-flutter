%!PS-Adobe-2.0 EPSF-1.2%%Title: 05.ng.EPSF%%Creator: Nightingale 5.0.8a0%%CreationDate: Tue, Mar 9, 2004 [12:45:48 pm]%%Pages: 1%%BoundingBox: 0 0 612 792%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF 16 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 792] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/MFS 16 def16 MF SQW/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def9072 1973 576 1973 SFL9072 2037 576 2037 SFL9072 2101 576 2101 SFL9072 2165 576 2165 SFL9072 2229 576 2229 SFL9072 2539 576 2539 SFL9072 2603 576 2603 SFL9072 2667 576 2667 SFL9072 2731 576 2731 SFL9072 2795 576 2795 SFL9072 1142 576 1142 SFL9072 1206 576 1206 SFL9072 1270 576 1270 SFL9072 1334 576 1334 SFL9072 1398 576 1398 SFL576 2797 576 1140 6 ML464 1973 411 BR/Times-Italic 9 NF(GB-Lbl Add 33933: \324Contra to Lachrimae\325)640 960 MS/Times-Italic 9 NF(GB-Cu Dd.3.18 \(f. 16v\))640 1813 MS16 MF SQW(&)640 2229 MS(?)640 2795 MS(&)640 1398 MS(b)864 2101 MS(b)864 2731 MS(\317)1079 2133 MS(\317)1079 2197 MS1079 1909 0 SU(\372)1079 2539 MS1079 2347 0 SU(\372)1079 2667 1079 2676 1079 2859 SD(\317)1079 1302 MS1079 1078 0 SU1452 2013 1662 2005 32 BM1452 1182 1662 1174 32 BM(\317)1381 2261 MS1381 2021 0 SU(\317)1381 1430 MS1381 1190 0 SU(\317)1587 2229 MS1587 2013 0 SU(\317)1587 1398 MS1587 1182 0 SU1865 1949 2076 1941 32 BM1865 1118 2076 1110 32 BM(\317)1794 2197 MS1794 1957 0 SU(\372)1794 2539 MS1794 2347 0 SU(\372)1794 2667 1794 2676 1794 2859 SD(\317)1794 1366 MS1794 1126 0 SU(\317)2001 2165 MS2001 1949 0 SU(\317)2001 1334 MS2001 1118 0 SU2321 2014 2613 2014 2629 2072  2261 2072 MC2613 2033 2321 2033 2261 2072 SL(\317)2208 2133 MS2208 1909 0 SU(\317)2208 1302 MS2208 1078 0 SU2510 2795 2510 1973 BL2510 1398 2510 1142 BL2684 1904 3102 1920 32 BM2684 1952 3102 1968 32 BM2684 1083 3102 1067 32 BM2684 1131 3102 1115 32 BM(\317)2613 2133 MS2613 1912 0 SU(\372)2613 2261 2613 2270 2613 2437 SD(\372)2613 2507 2613 2516 2613 2699 SD(\317)2613 1430 MS2613 1091 0 SU(\317)2751 2133 MS2751 1917 0 SU(\317)2751 1302 MS2751 1086 0 SU(\317)2889 2165 MS2889 1923 0 SU(\317)2889 1334 MS2889 1081 0 SU(\317)3027 2197 MS3027 1928 0 SU(\317)30