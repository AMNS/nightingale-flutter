%!PS-Adobe-2.0 EPSF-1.2%%Title: Schildt.ng.EPSF%%Creator: Nightingale 5.0.7a9%%CreationDate: Tue, Mar 9, 2004 [6:24:10 pm]%%Pages: 1%%BoundingBox: 0 0 594 841%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF 16 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 841] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/MFS 16 def16 MF SQW/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def9072 961 576 961 SFL9072 1025 576 1025 SFL9072 1089 576 1089 SFL9072 1153 576 1153 SFL9072 1217 576 1217 SFL9072 1820 576 1820 SFL9072 1884 576 1884 SFL9072 1948 576 1948 SFL9072 2012 576 2012 SFL9072 2076 576 2076 SFL576 2078 576 959 6 ML464 961 557 BR(&)640 1217 MS(?)640 2076 MS(\317)978 1089 978 1098 978 1313 SD/Times-Italic 8 NF(9)1239 865 MS1239 2076 1239 961 BL1522 937 2146 937 2253 992  1405 992 MC2146 956 1522 956 1405 992 SL1421 1604 2093 1596 32 BM16 MF SQW(\372)1350 1057 MS1350 865 0 SU(\372)1350 2044 1350 2053 1350 2236 SD(\372)1350 1217 1350 1226 1350 1409 SD(\317)1350 1820 MS1350 1612 0 SU(\317)1573 1916 MS1573 1610 0 SU(\317)1795 1820 MS1795 1607 0 SU(\317)2018 1788 MS2018 1604 0 SU2312 833 2984 833 32 BM(\317)2241 1057 MS2241 841 0 SU(\372)2241 1820 2241 1829 2241 2012 SD(\317)2241 1217 2241 1226 2241 1409 SD2337 1756 2217 1756 LL(\372)2241 1756 MS2241 1580 0 SU(\317)2463 1121 MS2463 841 0 SU(\317)2686 1025 MS2686 841 0 SU(#)2614 1185 MS(\317)2686 1185 2686 1194 2686 1377 SD(\317)2909 1057 MS2909 841 0 SU3131 2076 3131 961 BL3410 969 4042 969 4149 1024  3293 1024 MC4042 988 3410 988 3293 1024 SL3242 2234 3910 2242 32 BM(\372)3242 1089 MS3242 897 0 SU(\317)3242 1852 3242 1861 3242 2266 SD(\372)3242 1153 3242 1162 3242 1345 SD3338 1756 3218 1756 LL(\372)3242 1724 MS3242 1548 0 SU(\317)3465 2076 3465 2085 3465 2268 SD(\317)3687 1852 3687 1861 3687 2271 SD(\317)3910 1884 3910 1893 3910 2274 SD4204 865 4876 865 32 BM4403 1573 4944 1573 5149 1632  4189 1632 MC4944 1592 4403 1592 4189 1632 SL(\317)4133 1089 MS4133 873 0 SU(\372)4133 1916 4133 1925 4133 2108 SD(\372)4133 1153 4133 1162 4133 1345 SD4229 1756 4109 1756 LL4229 1692 4109 1692 LL(\372)4133 1692 MS4133 1516 0 SU(\317)4355 1153 MS4355 873 0 SU(\317)4578