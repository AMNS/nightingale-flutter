%!PS-Adobe-2.0 EPSF-1.2%%Title: 04.ng.EPSF%%Creator: Nightingale 5.0.8a0%%CreationDate: Tue, Mar 9, 2004 [12:48:05 pm]%%Pages: 1%%BoundingBox: 0 0 612 792%%DocumentFonts: (atend)%%EndComments/NightTopSave save defuserdict /NightingaleDict 80 dict putNightingaleDict begin/BD {bind def}bind def/XD {exch def} BD/BP {/SV save def} BD/EP {SV restore} BD/MS {moveto show} BD/MSI {moveto stringwidth rmoveto} BD/XF {transform 0.25 sub round 0.25 add exch 0.25 sub round 0.25 add exch itransform} BD/DXF {0 dtransform round exch round exch idtransform pop} BD/MC {newpath moveto curveto} BD/SL {curveto closepath fill} BD/ML {setlinewidth XF moveto XF lineto stroke} BD/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def/STW {stw setlinewidth} BD/BL {blw ML} BD/SFL {sfw ML} BD/LL {ldw ML} BD/SDO {exch stw 2 div add exch XF} BD/SUO {exch stw 2 div sub exch XF} BD/SQW {/qw (\317)stringwidth pop def} def% /SUNOMORE {STW currentpoint qw 10 div sub SUO moveto exch qw add exch SUO lineto stroke} BD/SU {STW currentpoint qw 10 div sub 3 -1 roll add SUO moveto exch qw add exch SUO lineto stroke} BD/Sd {STW SDO moveto dup 0 lt {pop pop XF moveto} {SDO lineto stroke XF moveto} ifelse} BD/SD {Sd show} BD/SDI {Sd qw 0 rmoveto} BD/BM {/th XD newpath 2 copy XF moveto th add XF lineto 2 copy th add XF lineto     XF lineto closepath fill} BD/LHT {/th XD newpath 2 copy XF moveto exch th add exch XF lineto 2 copy exch th add exch XF     lineto XF lineto closepath fill} BD/BMU {BM} BD/BMD {BM} BD/BK {XF/y XD/x XD/h XD/bkw(\302)stringwidth pop .36275 mul def     (\302)x y MS x y moveto x y h add lineto		% 302 = Â     x bkw add y h add lineto x bkw add y lineto closepath fill     (L)x y h add MS} BD/CH {				%	char  --  top bottom	gsave		false charpath pathbbox			%  leaves   llx lly urx ury   on stack		exch pop 3 -1 roll pop exch		%  leaves   ury lly	   on stack	grestore} BD/braceOrigX 211 def/braceOrigY 346 def/braceHalfHt 559 braceOrigY sub def/bracePWidth 20 def		% ourBrace is for music font size of this many points/pT {braceOrigY sub exch braceOrigX sub exch} BD   % Offset stacked points to an origin/ourBrace {						% Coords sucked out of a FH 3.1 EPS drawing of half brace  newpath  278 559 pT moveto  242 543 pT 178 485 pT 232 408 pT curveto  248.769 384.0886 pT 255 355 pT braceOrigX braceOrigY pT curveto  269 350 pT 290.47 384.8833 pT 267 424 pT curveto  246 459 pT 225 510 pT 278 559 pT curveto  closepath } BD/BR {   /ht XD/yTop XD/xLeft XD   gsave   xLeft yTop ht add translate   0 0 moveto   (\247)CH/cBot XD/cTop XD   cBot cTop eq      % if equal, no PostScript font around, so homebrew it   {      MFS bracePWidth div ht braceHalfHt div scale  % Stretch brace H for staff size, V to ht      ourBrace fill      1.0 -1.0 scale                    % Flip vertically to do other half      ourBrace fill   }   {      /cht cTop cBot sub abs def         % Use PostScript font      1.0 ht cht div scale      gsave      0 cBot abs neg rmoveto(\247)show      grestore      (\352)CH/cBot XD/cTop XD      /cht cTop cBot sub abs def      0 cTop abs rmoveto(\352)show   }   ifelse   grestore} BD% Create encoding vector for Mac Fonts/MacEncoding 256 array def% Copy first 128 entries of Times-Roman (standard ASCII) encoding into MacEncodingMacEncoding 0     /Times-Roman findfont /Encoding get    0 128 getinterval    putinterval% Fix up a few strays in lower 128MacEncoding 16#27 /quotesingle putMacEncoding 16#60 /grave put% Now define the encoding for the upper 128 chars/Adieresis /Aring /Ccedilla /Eacute /Ntilde /Odieresis /Udieresis /aacute/agrave /acircumflex /adieresis /atilde /aring /ccedilla /eacute /egrave/ecircumflex /edieresis /iacute /igrave /icircumflex /idieresis /ntilde /oacute/ograve /ocircumflex /odieresis /otilde /uacute /ugrave /ucircumflex /udieresis/dagger /degree /cent /sterling /section /bullet /paragraph /germandbls/registersans /copyrightsans /trademarksans /acute /dieresis /notequal /AE /Oslash/infinity /plusminus /lessequal /greaterequal /yen /mu /partialdiff /summation/product /pi /integral /ordfeminine /ordmasculine /Omega /ae /oslash/questiondown /exclamdown /logicalnot /radical /florin /approxequal /Delta /guillemotleft/guillemotright /ellipsis /space /Agrave /Atilde /Otilde /OE /oe/endash /emdash% 210 - 213 decimal == D2 - D5 hex/quotedblleft /quotedblright /quoteleft /quoteright/divide /lozenge/ydieresis /Ydieresis /fraction /currency /guilsinglleft /guilsinglright /fi /fl/daggerdbl /periodcentered /quotesinglbase /quotedblbase /perthousand/Acircumflex /Ecircumflex /Aacute/Edieresis /Egrave /Iacute /Icircumflex /Idieresis /Igrave /Oacute /Ocircumflex/apple /Ograve /Uacute /Ucircumflex /Ugrave /dotlessi /circumflex /tilde/macron /breve /dotaccent /ring /cedilla /hungarumlaut /ogonek /caronMacEncoding 128 128 getintervalastore pop% Build new font names for re-encoded fonts/tmpname 72 string def/concatname {		% prefixStr /oldname -- /newname	1 index length /prelen exch def		% Store length of prefix string	dup length prelen add tmpname exch 0 exch getinterval	dup prelen 4 -1 roll dup length string cvs putinterval	dup 0 4 -1 roll putinterval	cvn	} bind def% Re-encode fonts we use for Mac character set/RE {	dup (|______) exch concatname /newname exch def	FontDirectory newname known		{pop FontDirectory newname get}		{			findfont begin				currentdict dup length dict begin					{1 index /FID eq {pop pop} {def} ifelse} forall					/FontName newname def					/Encoding MacEncoding def					newname currentdict definefont					end				end		} ifelse	} bind def/MFS 24 def/DCF 16 def/SDCF 16 100 100 div mul def/MX [1 SDCF div 0 0 -1 SDCF div 0 792] def/FM MX matrix copy def/IDMX matrix def/FMX {[DCF 0 0 DCF neg 0 0] MFS dup IDMX scale FM concatmatrix} BD/NF {exch RE exch DCF mul dup neg FMX scale makefont setfont} BD/MF {/Sonata findfont exch DCF mul dup neg FMX scale makefont setfont} BDend         % NightingaleDict%%EndProlog%%Page: ? 1NightingaleDict beginBPMX concat/Times-Roman 10 NF(*)3520 1856 MS/Times-Roman 8 NF(LoST:)3648 1848 MS 9 MFSQW(q    q)4000 1834 MS/MFS 16 def16 MF SQW/stw 5 def/blw 6 def/ldw 8 def/sfw 5 def9072 961 576 961 SFL9072 1025 576 1025 SFL9072 1089 576 1089 SFL9072 1153 576 1153 SFL9072 1217 576 1217 SFL(&)640 1217 MS/Times-Roman 9 NF(Ex)908 1441 MS/Times-Roman 9 NF(-)1128 1441 MS16 MF SQW(\317)958 1121 MS958 897 0 SU/Times-Roman 9 NF(ilde)1240 1441 MS16 MF SQW(\317)1327 1217 MS1327 993 0 SU(.)1439 1185 MS/Times-Roman 9 NF(for)1719 1441 MS16 MF SQW(\317)1779 1217 MS1779 993 0 SU(j)1779 1217 MS2101 929 2397 929 32 BM/Times-Roman 9 NF(ev)1989 1441 MS16 MF SQW(\317)2030 1153 MS2030 937 0 SU/Times-Roman 9 NF(er  :)2272 1441 MS/Times-Roman 9 NF(-)2190 1441 MS16 MF SQW(\317)2322 1153 MS2322 937 0 SU2575 1217 2575 961 BL/Times-Roman 9 NF(let)2695 1441 MS16 MF SQW(\317)2736 1185 MS2736 961 0 SU/Times-Roman 9 NF(mee)3059 1441 MS16 MF SQW(\317)3156 1249 MS3156 1025 0 SU/Times-Roman 9 NF(morne)3413 1441 MS/Times-Roman 10 NF(*)3588 897 MS16 MF SQW(\317)3588 1217 MS3588 993 0 SU(.)3700 1185 MS/Times-Roman 9 NF(where)3939 1441 MS16 MF SQW(\317)4104 1089 4104 1098 4104 1313 SD(J)4104 1089 MS4440 1217 4440 961 BL/Times-Roman 9 NF(nights)4560 1441 MS16 MF SQW(\317)4725 1057 4725 1066 4725 1281 SD/Times-Roman 9 NF(black)5048 1441 MS16 MF SQW(\317)5194 1121 MS5194 897 0 SU/Times-Roman 9 NF(bird)5518 1441 MS16 MF SQW(\317)5615 1089 5615 1098 5615 1313 SD/Times-Roman 9 NF(hir)5987 1441 MS16 MF SQW(#)5965 1153 MS(\317)6037 1153 MS6037 929 0 SU6461 1217 6461 961 BL/Times-Roman 9 NF(sad)6579 1441 MS16 MF SQW(\317)6649 1121 MS6649 897 0 SU/Times-Roman 9 NF(in)7052 1441 MS16 MF SQW(\317)7073 1057 7073 1066 7073 1281 SD(.)7185 1057 MS/Times-Roman 9 NF(fa)7567 1441 MS/Times-Roman 9 NF(-)7346 1441 MS/Times-Roman 9 NF(-)7720